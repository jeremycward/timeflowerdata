

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/ninetynine_data.schema.json",
  "title": "NinetyNine Timeline Data",
  "type": "object",
  "required": ["start", "end", "tracks"],
  "additionalProperties": false,
  "properties": {
    "start": { "$ref": "#/$defs/dateString" },
    "end": { "$ref": "#/$defs/dateString" },
    "tracks": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/track99Ages" },
          { "$ref": "#/$defs/trackSeries" },
          { "$ref": "#/$defs/trackTimeSeries" },
          { "$ref": "#/$defs/trackEvents" }
        ]
      }
    }
  },
  "$defs": {
    "dateString": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date in YYYY-MM-DD format"
    },
    "uriOrPath": {
      "type": "string"
    },
    "trackHeightBase": {
      "type": "object",
      "required": ["collapsedHeight", "expandedHeight"],
      "additionalProperties": false,
      "properties": {
        "collapsedHeight": { "type": "number" },
        "expandedHeight": { "type": "number" },
        "collapsible": { "type": "boolean" },
        "defaultMode": {
          "type": "string",
          "enum": ["collapsed", "expanded"]
        }
      }
    },
    "ageItem": {
      "type": "object",
      "required": ["name", "itemcolor", "heading", "detail1", "detail2", "start", "end", "id"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "itemcolor": { "type": "string" },
        "heading": { "type": "string" },
        "detail1": { "type": "string" },
        "detail2": { "type": "string" },
        "start": { "$ref": "#/$defs/dateString" },
        "end": { "$ref": "#/$defs/dateString" },
        "id": { "type": "string" },
        "img": { "$ref": "#/$defs/uriOrPath" },
        "remote_info": { "$ref": "#/$defs/uriOrPath" }
      }
    },
    "seriesItem": {
      "type": "object",
      "required": ["name", "itemcolor", "heading", "detail1", "detail2", "start", "end", "id"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "itemcolor": { "type": "string" },
        "heading": { "type": "string" },
        "detail1": { "type": "string" },
        "detail2": { "type": "string" },
        "start": { "$ref": "#/$defs/dateString" },
        "end": { "$ref": "#/$defs/dateString" },
        "id": { "type": "string" },
        "img": { "$ref": "#/$defs/uriOrPath" },
        "remote_info": { "$ref": "#/$defs/uriOrPath" }
      }
    },
    "timeSeriesPoint": {
      "type": "object",
      "required": ["value", "date"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": "number" },
        "date": { "$ref": "#/$defs/dateString" }
      }
    },
    "timeSeriesItem": {
      "type": "object",
      "required": ["name", "start", "end", "id", "timeSeriesPlots"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "start": { "$ref": "#/$defs/dateString" },
        "end": { "$ref": "#/$defs/dateString" },
        "id": { "type": "string" },
        "remote_info": { "$ref": "#/$defs/uriOrPath" },
        "timeSeriesPlots": {
          "type": "array",
          "items": { "$ref": "#/$defs/timeSeriesPoint" }
        }
      }
    },
    "eventItem": {
      "type": "object",
      "required": ["id", "name", "detail1", "detail2", "date"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "detail1": { "type": "string" },
        "detail2": { "type": "string" },
        "date": { "$ref": "#/$defs/dateString" }
      }
    },
    "eventGroupItem": {
      "type": "object",
      "required": ["start", "end", "id", "eventItems"],
      "additionalProperties": false,
      "properties": {
        "start": { "$ref": "#/$defs/dateString" },
        "end": { "$ref": "#/$defs/dateString" },
        "id": { "type": "string" },
        "remote_info": { "$ref": "#/$defs/uriOrPath" },
        "eventItems": {
          "type": "array",
          "items": { "$ref": "#/$defs/eventItem" }
        }
      }
    },
    "track99Ages": {
      "type": "object",
      "required": ["type", "id", "trackHeight", "header", "items"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "99AGES" },
        "id": { "type": "string" },
        "throwshadow": { "type": "boolean" },
        "trackHeight": { "$ref": "#/$defs/trackHeightBase" },
        "header": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/ageItem" }
        }
      }
    },
    "trackSeries": {
      "type": "object",
      "required": ["type", "id", "trackHeight", "header", "items"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "SER" },
        "id": { "type": "string" },
        "trackHeight": { "$ref": "#/$defs/trackHeightBase" },
        "header": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/seriesItem" }
        }
      }
    },
    "trackTimeSeries": {
      "type": "object",
      "required": ["type", "id", "trackHeight", "header", "items"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "TSE" },
        "id": { "type": "string" },
        "trackHeight": { "$ref": "#/$defs/trackHeightBase" },
        "header": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/timeSeriesItem" }
        }
      }
    },
    "trackEvents": {
      "type": "object",
      "required": ["type", "id", "trackHeight", "header", "items"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "EVE" },
        "id": { "type": "string" },
        "trackHeight": { "$ref": "#/$defs/trackHeightBase" },
        "header": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/eventGroupItem" }
        }
      }
    }
  }
}
